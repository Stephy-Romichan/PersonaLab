# Persona Lab — environment template
# Copy this file to `.env` and fill in your keys. NEVER commit your real .env.
#   cp .env.template .env

# --- API keys (only needed when USE_MOCKS = False, i.e. M3+) ---
# Google AI Studio (Gemini 2.5 Flash-Lite — Persona Panel). Free tier eligible.
#   Get one: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI (GPT-4o-mini — Moderator)
#   Get one: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (Claude Haiku 4.5 — Strategist)
#   Get one: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Pipeline flag ---
# True  = mocks only, $0, no installs needed (M1/M2)
# False = real API calls (flip at M3)
USE_MOCKS=True
